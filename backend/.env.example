APP_NAME=School Management System
DEBUG=True

# Dev: SQLite
DATABASE_URL=sqlite:///./school.db

# Prod example:
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

JWT_SECRET=replace_with_a_strong_random_secret
