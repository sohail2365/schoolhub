APP_NAME=School Management System
DEBUG=True

# Dev: SQLite
DATABASE_URL=sqlite:///./school.db

# Prod example:
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

JWT_SECRET=replace_with_a_strong_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

CORS_ORIGINS=*

LOG_FILE=logs/app.log
API_V1_PREFIX=/api/v1

# Password reset emails (optional). If left blank, reset links are logged
# to the server console instead of emailed — fine for local dev, but set
# these for real deployments. Works with Gmail using an App Password:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=School Hub

# Used to build the password reset link. Set this to your deployed URL
# (e.g. https://schoolhub-ivory.vercel.app) in production.
FRONTEND_BASE_URL=http://127.0.0.1:8000

# AI features (optional) — student summaries & class reports via Groq.
# Get a free API key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
